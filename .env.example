# ─── LLM Provider ────────────────────────────────────────────────────────────
# LLM_API_KEY   Your API key (required).
# LLM_BASE_URL  Base URL for any /v1/chat/completions-compatible endpoint.
#               Defaults to https://api.openai.com/v1
#               Examples:
#                 OpenAI (default)   https://api.openai.com/v1
#                 Anthropic proxy    https://your-proxy/v1
#                 Google Gemini      https://generativelanguage.googleapis.com/v1beta/openai
#                 Ollama (local)     http://localhost:11434/v1
#                 LM Studio          http://localhost:1234/v1
# LLM_MODEL     Model identifier. Defaults to gpt-4.1-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ─── Backward-compatible aliases (deprecated — use LLM_* vars above) ─────────
# OPENAI_API_KEY, OPENAI_BASE_URL, OPENAI_MODEL are still accepted as fallbacks.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
